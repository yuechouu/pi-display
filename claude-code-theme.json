{
  "name": "claude-code",
  "description": "Claude Code inspired theme — clean, minimal, no green",
  "vars": {
    "primary": "#d4a574",
    "secondary": "#8ab4f8",
    "bg": "#1a1a1a",
    "surface": "#252525",
    "border": "#3a3a3a",
    "text": "#e8e8e8",
    "muted": "#888888",
    "dim": "#606060",
    "success": "#8ab4f8",
    "error": "#f28b82",
    "warning": "#fdd663",
    "accent": "#8ab4f8"
  },
  "fg": {
    "accent": "$primary",
    "border": "$border",
    "borderAccent": "$primary",
    "borderMuted": "$border",
    "success": "$success",
    "error": "$error",
    "warning": "$warning",
    "muted": "$muted",
    "dim": "$dim",
    "text": "$text",
    "thinkingText": "$muted",
    "userMessageText": "$text",
    "customMessageText": "$text",
    "customMessageLabel": "$primary",
    "toolTitle": "$text",
    "toolOutput": "$muted",
    "mdHeading": "$primary",
    "mdLink": "$secondary",
    "mdLinkUrl": "$dim",
    "mdCode": "$text",
    "mdCodeBlock": "$text",
    "mdCodeBlockBorder": "$border",
    "mdQuote": "$muted",
    "mdQuoteBorder": "$border",
    "mdHr": "$border",
    "mdListBullet": "$primary",
    "toolDiffAdded": "#81c995",
    "toolDiffRemoved": "#f28b82",
    "toolDiffContext": "$muted",
    "syntaxComment": "$dim",
    "syntaxKeyword": "#c586c0",
    "syntaxFunction": "$secondary",
    "syntaxVariable": "$text",
    "syntaxString": "#ce9178",
    "syntaxNumber": "#b5cea8",
    "syntaxType": "$primary",
    "syntaxOperator": "$text",
    "syntaxPunctuation": "$muted",
    "thinkingOff": "$border",
    "thinkingMinimal": "$border",
    "thinkingLow": "$border",
    "thinkingMedium": "$border",
    "thinkingHigh": "$primary",
    "thinkingXhigh": "$primary",
    "bashMode": "$muted"
  },
  "bg": {
    "selectedBg": "#2a2a2a",
    "userMessageBg": "",
    "customMessageBg": "",
    "toolPendingBg": "#1e1e1e",
    "toolSuccessBg": "#1a2332",
    "toolErrorBg": "#2a1a1a"
